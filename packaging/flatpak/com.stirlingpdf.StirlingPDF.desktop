[Desktop Entry]
Version=1.0
Type=Application
Name=Stirling-PDF
Comment=Locally hosted web application that allows you to perform various operations on PDF files
TryExec=stirling-pdf-launcher
Exec=stirling-pdf-launcher %F
Icon=com.stirlingpdf.StirlingPDF
Terminal=false
MimeType=application/pdf;
Categories=Office;Graphics;Utility;
StartupWMClass=Stirling-PDF
Actions=open-file;

[Desktop Action open-file]
Name=Open PDF File
Exec=stirling-pdf-launcher %F
